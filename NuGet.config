<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Temporary local feed carrying a rebuilt Microsoft.SemanticKernel.Connectors.PgVector
         compiled against Npgsql 10.0.2, to work around the MissingMethodException on
         NpgsqlConnection.ReloadTypesAsync() (the official 1.74.0-preview was compiled
         against Npgsql 8.x). Remove this feed and revert to nuget.org once SK publishes
         the next preview with the fix merged in microsoft/semantic-kernel#13724. -->
    <add key="local-sk-fix" value="./local-nuget" />
  </packageSources>
</configuration>
